    {
      "cell_type": "code",
      "source": [
        "#OOPS\n",
        "#four pillar\n",
        "\n",
        "#encapsulation\n",
        "#(Binding data and methods together into a single unit (class) and restricting direct access.)\n",
        "\n",
        "#inheritance\n",
        "#(One class acquires properties and methods of another class.)\n",
        "#four types of inheritances\n",
        "# (1).single Inheritance (2).multiple Inheritance\n",
        "# (3).multilevel Inheritance (4).Hierarchical Inheritance\n",
        "\n",
        "#abstraction\n",
        "#(Showing only necessary details and hiding implementation.)\n",
        "\n",
        "#Polymorphism\n",
        "#(One function behaves differently in different situations.)\n"
      ],
      "metadata": {
        "id": "dtYKmmOb9QvF"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "class mirai_class:\n",
        "  strength=100\n",
        "  teacher=['a','b','c']\n",
        "  div=['alpha','beta']\n",
        "  sub=['ds','dsa','webdev']\n",
        "\n",
        "  # constructor(call itself when object is created)\n",
        "  def __init__(self):\n",
        "    print('hello')\n",
        "\n",
        "obj=mirai_class()\n",
        "print(obj.strength)\n"
      ],
