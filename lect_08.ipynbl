          "name": "stdout",
          "text": [
            "Coding\n",
            "Cooking\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "#Polymorphism\n",
        "class Complex:\n",
        "\n",
        "    def __init__(self, x, y):\n",
        "        self.x = x\n",
        "        self.y = y\n",
        "\n",
        "    def __add__(self, other):\n",
        "        a = self.x + other.x\n",
        "        b = self.y + other.y\n",
        "        return Complex(a, b)\n",
        "\n",
        "    def display(self):\n",
        "        print(self.x, \"+ i\", self.y)\n",
        "\n",
        "\n",
        "a = Complex(2, 3)\n",
        "b = Complex(4, 3)\n",
        "\n",
        "c = a + b\n",
        "\n",
        "print(c.x, c.y)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
