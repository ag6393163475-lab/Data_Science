      "source": [
        "# encapsulation\n",
        "class student:\n",
        "  def __init__(self,name,age):\n",
        "\n",
        "    self.name=name\n",
        "    self.age=age\n",
        "\n",
        "\n",
        "  def display(self):\n",
        "\n",
        "    print('name:',self.name)\n",
        "    print('age:',self.age)\n",
        "\n",
        "a=student('anshika',20)\n",
        "print(a.name)\n",
        "print(a.age)"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# inheritance(single)\n",
        "class person:\n",
        "  def __init__(self,h,w,age):\n",
        "\n",
        "    self.height=h\n",
        "    self.weight=w\n",
        "    self.age=age\n",
        "\n",
        "class Anshika(person):\n",
        "\n",
        "  def __init__(self , g,name,b,h,w,age):\n",
        "\n",
        "    super().__init__(h,w,age)\n",
        "\n",
        "    self.gender=g\n",
        "    self.name = name\n",
        "    self.bank_balance = b\n",
        "\n",
        "obj=Anshika( \"female\",\"anshika\",100,5,55,19)\n",
        "print(obj.bank_balance)\n",
        "print(obj.age)\n"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "BiHzacZG7B8V",
        "outputId": "536c7ade-5007-4432-f9c2-5f8e918e329e"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "100\n",
            "19\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# multiple inheritance\n",
        "class Father:\n",
        "    def skill1(self):\n",
        "        print(\"Coding\")\n",
        "\n",
        "class Mother:\n",
        "    def skill2(self):\n",
        "        print(\"Cooking\")\n",
        "\n",
        "class Child(Father, Mother):\n",
        "    pass\n",
        "\n",
        "c = Child()\n",
        "\n",
        "c.skill1()\n",
        "c.skill2()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "8j2k_kiH8QxQ",
        "outputId": "075c4aa9-cb9a-4338-cc9f-1c3061be1a1b"
      },
      "execution_count": 1,
      "outputs": [
        {
