        "#COUNT THE NUMBER OF -VE IN ECAH COLUMN\n",
        "\n",
        "\n",
        "import numpy as np\n",
        "# arange\n",
        "a = np.random.randint(1,90,25, dtype=int)\n",
        "b=a.reshape(5,5)\n",
        "print(b)\n",
        "\n",
        "#mean\n",
        "print(np.mean(b,axis=0))\n",
        "print(np.mean(b,axis=1))\n",
        "\n",
        "#replace -1\n",
        "mofified_a=np.where(a%2==0,-1 ,a)\n",
        "print(mofified_a)\n",
        "\n",
        "#sort\n",
        "print(np.sort(b,axis=0))\n",
        "print(np.sort(b,axis=1))\n",
        "\n",
        "#sum\n",
        "print(np.sum(b,axis=0))\n",
        "print(np.sum(b,axis=1))\n",
        "\n",
        "#count -1\n",
        "t_a=np.sum(np.where(mofified_a<0 , 1, 0),axis=0)\n",
