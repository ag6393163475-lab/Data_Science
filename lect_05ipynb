        "#ques\n",
        "#CRAETE a 5*5 matrix of random integers(1-90)\n",
        "#FIND MEAN SOF VALUE ROW AND COLUMN WISE\n",
        "#REPLACE ALL EVEN NUMBERS WITH -1\n",
