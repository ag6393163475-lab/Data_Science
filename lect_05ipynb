        "#ques\n",
        "#craete a 5*5 array(stock level)\n",
        "#create another 5*5 array(demand)\n",
        "#compur:\n",
        "#remaining stock=stock-demand\n",
        "#replace:\n",
        "#negative values=0(out of stock)\n",
        "#find:\n",
        "# total storage\n",
        "#product with xero stock\n",
        "#sort each row base on reamining stock\n",
        "\n",
        "#stock level\n",
        "a = np.random.randint(1,90, (5,5))\n",
        "# b=a.reshape(5,5)\n",
        "print(a)\n",
        "\n",
        "#demand\n",
        "a1 = np.random.randint(1,90,(5,5))\n",
        "print(a1)\n",
        "\n",
        "#remaining_stock\n",
        "remainimg_stock=a-a1\n",
        "print(remainimg_stock)\n",
        "\n",
        "#replace_remainimg_stock\n",
        "replace_remainimg_stock=np.where(remainimg_stock<0, 0 ,remainimg_stock)\n",
        "print(replace_remainimg_stock)\n",
        "\n",
        "\n",
        "#total shortage\n",
        "t_remainimg_stock=np.sum(np.where(remainimg_stock<0,remainimg_stock*-1,0),axis=0)\n",
        "print(t_remainimg_stock)\n",
        "\n",
        "\n",
        "#product with zero stock\n",
        "product_shortage=np.sum(np.where(remainimg_stock==0,1,0),axis=0)\n",
        "print(product_shortage)\n",
        "\n",
        "#sort\n",
        "sorted=np.sort(replace_remainimg_stock,axis=1)\n",
        "print(sorted)\n",
        "\n"
